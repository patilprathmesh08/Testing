name: Code Quality Checks

on:
  push:
    branches:
      - main
      - MotorCode
  pull_request:
    branches:
      - main
      - MotorCode

jobs:
  code-quality:
    name: Code Quality Checks
    runs-on: ubuntu-latest

    steps:
      # Step 1 - Checkout code
      - name: Checkout Repository
        uses: actions/checkout@v4
        with:
          fetch-depth: 0  # Required for SonarCloud to analyze full history

      # Step 2 - Install ARM GCC Toolchain
      - name: Install ARM GCC Toolchain
        run: |
          sudo apt-get update
          sudo apt-get install -y gcc-arm-none-eabi binutils-arm-none-eabi

      # Step 3 - Install Ninja
      - name: Install Ninja
        run: sudo apt-get install -y ninja-build

      # Step 4 - Install CMake
      - name: Install CMake
        uses: jwlawson/actions-setup-cmake@v2
        with:
          cmake-version: '3.27'

      # Step 5 - Install Doxygen
      - name: Install Doxygen
        run: sudo apt-get install -y doxygen graphviz

      # ─── CHECK 1: HEADER AND COPYRIGHT NOTICE ───────────────────────────────

      # Step 6 - Check all .c and .h files have copyright/header notice
      - name: Check File Headers and Copyright Notice
        run: |
          echo "Checking copyright headers in all .c and .h files..."
          MISSING=0
          # Search inside CNR-Motor-Driver-1.0 folder
          while IFS= read -r file; do
            if ! grep -q "Copyright\|copyright\|LICENSE\|license\|Author\|author" "$file"; then
              echo "MISSING HEADER: $file"
              MISSING=$((MISSING + 1))
            fi
          done < <(find CNR-Motor-Driver-1.0 -name "*.c" -o -name "*.h")
          if [ "$MISSING" -gt 0 ]; then
            echo "---"
            echo "FAILED: $MISSING file(s) are missing copyright/header notice."
            echo "Please add a copyright header to each file listed above."
            exit 1
          else
            echo "PASSED: All files have copyright/header notice."
          fi

      # ─── CHECK 2: DOXYGEN COMMENT BLOCKS ────────────────────────────────────

      # Step 7 - Generate Doxyfile if not present
      - name: Setup Doxyfile
        working-directory: CNR-Motor-Driver-1.0
        run: |
          if [ ! -f Doxyfile ]; then
            echo "No Doxyfile found, generating default..."
            doxygen -g Doxyfile
            # Configure Doxygen for C/C++ project
            sed -i 's/PROJECT_NAME           = "My Project"/PROJECT_NAME           = "CNR-BLDC-MOTOR-FOC"/' Doxyfile
            sed -i 's/INPUT                  =/INPUT                  = Src Inc/' Doxyfile
            sed -i 's/RECURSIVE              = NO/RECURSIVE              = YES/' Doxyfile
            sed -i 's/EXTRACT_ALL            = NO/EXTRACT_ALL            = YES/' Doxyfile
            sed -i 's/WARN_IF_UNDOCUMENTED   = YES/WARN_IF_UNDOCUMENTED   = YES/' Doxyfile
          fi

      # Step 8 - Run Doxygen and check for errors/warnings
      - name: Run Doxygen Check
        working-directory: CNR-Motor-Driver-1.0
        run: |
          echo "Running Doxygen..."
          doxygen Doxyfile 2>&1 | tee doxygen_output.log
          # Check for critical errors
          if grep -i "error" doxygen_output.log; then
            echo "FAILED: Doxygen found critical errors."
            exit 1
          else
            echo "PASSED: No critical Doxygen errors found."
          fi

      # Step 9 - Upload Doxygen log as artifact
      - name: Upload Doxygen Log
        uses: actions/upload-artifact@v4
        if: always()
        with:
          name: doxygen-log
          path: CNR-Motor-Driver-1.0/doxygen_output.log
          retention-days: 7

      # ─── CHECK 3: SONARCLOUD ANALYSIS ───────────────────────────────────────

      # Step 10 - Run SonarCloud Scan (Security, Reliability, Maintenance)
      - name: SonarCloud Scan
        uses: SonarSource/sonarcloud-github-action@master
        env:
          GITHUB_TOKEN: ${{ secrets.GITHUB_TOKEN }}  # GitHub token for PR analysis
          SONAR_TOKEN: ${{ secrets.SONAR_TOKEN }}    # SonarCloud token
        with:
          args: >
            -Dsonar.organization=patilprathmesh08
            -Dsonar.projectKey=patilprathmesh08_Testing
            -Dsonar.sources=CNR-Motor-Driver-1.0/Src
            -Dsonar.cfamily.compile-commands=CNR-Motor-Driver-1.0/build/Debug/compile_commands.json
            -Dsonar.c.file.suffixes=.c
            -Dsonar.cpp.file.suffixes=.cpp,.cc
            -Dsonar.h.file.suffixes=.h
