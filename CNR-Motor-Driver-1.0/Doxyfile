# Doxyfile for CNR-BLDC-MOTOR-FOC STM32G431 Project
# Version: v2
# Date: 22-07-2026

#---------------------------------------------------------------------------
# Project Information
#---------------------------------------------------------------------------
PROJECT_NAME           = "Testing"
PROJECT_NUMBER         = "v1.0"
PROJECT_BRIEF          = "CNR BLDC Motor FOC - STM32G431 Firmware"
OUTPUT_DIRECTORY       = docs

#---------------------------------------------------------------------------
# Input Configuration
#---------------------------------------------------------------------------
INPUT                  = Src Inc
RECURSIVE              = YES
FILE_PATTERNS          = *.c *.h
EXCLUDE_PATTERNS       = */build/* */Drivers/* */MCSDK_v6.4.2-Full/*

#---------------------------------------------------------------------------
# Output Configuration - HTML only
#---------------------------------------------------------------------------
GENERATE_HTML          = YES
HTML_OUTPUT            = html
HTML_FILE_EXTENSION    = .html
GENERATE_LATEX         = NO
GENERATE_XML           = YES
GENERATE_MAN           = NO
GENERATE_RTF           = NO
GENERATE_DOCBOOK       = NO

#---------------------------------------------------------------------------
# Disable extra files
#---------------------------------------------------------------------------
HTML_DYNAMIC_MENUS     = NO
SEARCHENGINE           = NO
SERVER_BASED_SEARCH    = NO
GENERATE_TREEVIEW      = NO
DISABLE_INDEX          = NO
HTML_DYNAMIC_SECTIONS  = NO
GENERATE_LEGEND        = NO
DOT_CLEANUP            = YES

#---------------------------------------------------------------------------
# Extraction Configuration
#---------------------------------------------------------------------------
EXTRACT_ALL            = YES
EXTRACT_PRIVATE        = YES
EXTRACT_STATIC         = YES
EXTRACT_LOCAL_METHODS  = YES

#---------------------------------------------------------------------------
# Documentation Configuration
#---------------------------------------------------------------------------
JAVADOC_AUTOBRIEF      = YES
INHERIT_DOCS           = YES

#---------------------------------------------------------------------------
# Warning Configuration
#---------------------------------------------------------------------------
WARNINGS               = YES
WARN_IF_UNDOCUMENTED   = YES
WARN_IF_DOC_ERROR      = YES
WARN_NO_PARAMDOC       = YES
WARN_FORMAT            = "$file:$line: $text"
WARN_LOGFILE           = doxygen_output.log

#---------------------------------------------------------------------------
# Source Code Display
#---------------------------------------------------------------------------
SOURCE_BROWSER         = YES
REFERENCED_BY_RELATION = YES
REFERENCES_RELATION    = YES

#---------------------------------------------------------------------------
# Diagram Configuration - disabled to avoid extra files
#---------------------------------------------------------------------------
HAVE_DOT               = NO
CLASS_DIAGRAMS         = NO

#---------------------------------------------------------------------------
# Encoding
#---------------------------------------------------------------------------
DOXYFILE_ENCODING      = UTF-8
INPUT_ENCODING         = UTF-8
OUTPUT_LANGUAGE        = English
